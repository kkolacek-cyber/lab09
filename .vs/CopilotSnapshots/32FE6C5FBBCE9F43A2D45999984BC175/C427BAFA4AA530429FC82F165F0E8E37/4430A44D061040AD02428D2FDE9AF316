using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;

namespace NotesApp {
    public partial class Form1 : Form {
        public Form1() {
            InitializeComponent();
        }

        private void Form1_Load(object sender, EventArgs e) {
            RefreshNotes();
        }

        private void btnNewNote_Click(object sender, EventArgs e) {
            Notes.AddNote(new Note("", tbNewNote.Text));
            RefreshNotes();
            tbNewNote.Clear();
        }

        private void RefreshNotes() {
            var notes = Notes.GetNotes();
            lbNotes.DataSource = null;
            lbNotes.DataSource = notes;
            lbNotes.DisplayMember = "Name";
            lbNotes.ValueMember = "Id";
            tbNote.Clear();
        }

        private void lbNotes_MouseDoubleClick(object sender, MouseEventArgs e) {
            var note = Notes.GetNote(((Note)lbNotes.Items[lbNotes.SelectedIndex]).Id);
            tbNote.Text = note.Content;
        }

        private void btnSave_Click(object sender, EventArgs e) {
            if (lbNotes.SelectedIndex == -1) {
                MessageBox.Show("Prvo odaberite bilješku koju želite pohraniti");
                return;
            }
            bool result = Notes.UpdateNote((Note)lbNotes.Items[lbNotes.SelectedIndex], tbNote.Text);
            if (result == false) {
                MessageBox.Show("Greška prilikom pohrane");
            }
        }

        private void btnDelete_Click(object sender, EventArgs e) {
            if (lbNotes.SelectedIndex == -1) {
                MessageBox.Show("Prvo odaberite bilješku koju želite obrisati");
                return;
            }

            DialogResult dialogResult = MessageBox.Show(
                "Jeste li sigurni da želite obrisati ovu bilješku?",
                "Potvrda brisanja",
                MessageBoxButtons.YesNo,
                MessageBoxIcon.Question
            );

            if (dialogResult == DialogResult.Yes) {
                var selectedNote = (Note)lbNotes.Items[lbNotes.SelectedIndex];
                bool result = Notes.DeleteNote(selectedNote.Id);
                if (result) {
                    RefreshNotes();
                    MessageBox.Show("Bilješka obrisana");
                } else {
                    MessageBox.Show("Greška prilikom brisanja");
                }
            }
        }

        private void btnUpdateName_Click(object sender, EventArgs e) {
            if (lbNotes.SelectedIndex == -1) {
                MessageBox.Show("Prvo odaberite bilješku koju želite preimenovati");
                return;
            }

            if (string.IsNullOrWhiteSpace(tbNoteName.Text)) {
                MessageBox.Show("Unesite novi naziv bilješke");
                return;
            }

            var selectedNote = (Note)lbNotes.Items[lbNotes.SelectedIndex];
            bool result = Notes.UpdateNoteName(selectedNote, tbNoteName.Text);
            if (result) {
                RefreshNotes();
                tbNoteName.Clear();
                MessageBox.Show("Naziv bilješke promijenjen");
            } else {
                MessageBox.Show("Greška prilikom promjene naziva");
            }
        }
    }
}
